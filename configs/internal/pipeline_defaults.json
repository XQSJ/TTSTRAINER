{
  "extends": "../system/vits_mobile_architecture.json",
  "text_generation": {
    "enabled": false,
    "provider": "builtin",
    "output": null,
    "root": null,
    "corpus_name": null,
    "reuse": true,
    "overwrite": false,
    "input": null,
    "sentences_per_language": 100,
    "request_batch_size": null,
    "seed": 1337,
    "allow_fewer": false,
    "categories": {
      "daily": 0.35,
      "question": 0.10,
      "number": 0.10,
      "date_time": 0.10,
      "money_unit": 0.10,
      "names_places": 0.10,
      "long_sentence": 0.10,
      "domain": 0.05
    },
    "domain": {
      "name": "mobile_assistant"
    },
    "filters": {
      "min_characters": 5,
      "max_characters": 180,
      "deduplicate": true,
      "reject_mixed_language": true,
      "require_g2p_pass": false
    }
  },
  "generation": {
    "enabled": true,
    "qwen_runtime": "installed",
    "qwen_source_path": null,
    "auto_download_models": true,
    "text_manifest": null,
    "raw_metadata": null,
    "voice_dataset_root": null,
    "include_metadata": [],
    "overwrite": false,
    "batch_size": 4,
    "candidates_per_text": 1,
    "models": {
      "voice_design": "voice-design-1.7b",
      "voice_clone": "base-1.7b"
    },
    "runtime": {
      "device": "auto",
      "dtype": "auto",
      "attention": "auto"
    },
    "audio_postprocess": {
      "enabled": true,
      "trim_edge_silence": true,
      "silence_threshold_dbfs": -45.0,
      "keep_edge_silence_seconds": 0.15
    },
    "generation_kwargs": {
      "max_new_tokens": 2048,
      "do_sample": true,
      "top_k": 50,
      "top_p": 1.0,
      "temperature": 0.9,
      "repetition_penalty": 1.05,
      "subtalker_dosample": true,
      "subtalker_top_k": 50,
      "subtalker_top_p": 1.0,
      "subtalker_temperature": 0.9
    }
  },
  "validation": {
    "enabled": true,
    "fraction": 0.05,
    "minimum_per_profile": 1,
    "maximum_per_profile": 100,
    "require_every_profile": true,
    "batch_size": 4,
    "every_epochs": 1,
    "metric": "mel",
    "export_checkpoint": "best",
    "seed": 1337
  },
  "quality": {
    "enabled": true,
    "fail_on_error": true,
    "progress_every_items": 200,
    "minimum_duration_seconds": 0.4,
    "maximum_duration_seconds": 30.0,
    "minimum_rms_dbfs": -45.0,
    "maximum_rms_dbfs": -6.0,
    "clipping_amplitude": 0.999,
    "maximum_clipping_ratio": 0.001,
    "maximum_dc_offset": 0.05,
    "silence_threshold_dbfs": -45.0,
    "maximum_edge_silence_seconds": 1.5,
    "minimum_units_per_second": 0.5,
    "maximum_units_per_second": 40.0,
    "semantic": {
      "enabled": false,
      "fail_on_error": true,
      "progress_every_items": 20,
      "asr": {
        "enabled": true,
        "model": "asr-small",
        "auto_download_model": false,
        "device": "cpu",
        "compute_type": "int8",
        "beam_size": 5,
        "maximum_error_rate": 0.15
      },
      "speaker": {
        "enabled": true,
        "model": "speaker-ecapa",
        "auto_download_model": false,
        "device": "cpu",
        "minimum_similarity": 0.25,
        "references": {}
      }
    }
  },
  "pipeline": {
    "generate_texts": true,
    "generate_samples": true,
    "phonemize": true,
    "validate": true,
    "train": true,
    "export": true,
    "validate_onnx": true
  },
  "logging": {
    "level": "INFO",
    "color": "auto",
    "third_party_level": "WARNING",
    "live_progress": true,
    "sample_progress_every_batches": 1,
    "sample_postprocess_every_files": 200
  }
}
